{% extends 'emails/layout.html.twig' %}

{% block title %}Запись создана — Avtomaster{% endblock %}

{% block content %}
    <h2 style="margin-top:0;">Ваша запись создана</h2>
    <p>Привет, <strong>{{ booking.client.firstName|default('Клиент') }}</strong>!</p>
    <p>Вы записались к мастеру. Ожидайте подтверждения.</p>

    <div class="info-box">
        <div class="info-row">
            <span class="label">Мастер</span>
            <span class="value">{{ booking.master.firstName|default('') }} {{ booking.master.lastName|default('') }}</span>
        </div>
        <div class="info-row">
            <span class="label">Услуга</span>
            <span class="value">{{ booking.service.name|default('') }}</span>
        </div>
        <div class="info-row">
            <span class="label">Дата</span>
            <span class="value">{{ booking.slot.date }}</span>
        </div>
        <div class="info-row">
            <span class="label">Время</span>
            <span class="value">{{ booking.slot.startTime }} — {{ booking.slot.endTime }}</span>
        </div>
        <div class="info-row">
            <span class="label">Стоимость</span>
            <span class="value">{{ booking.total }} ₽</span>
        </div>
    </div>

    <p style="text-align:center;">
        <a href="{{ frontend_url }}/booking/{{ booking.id }}" class="btn">Перейти к записи</a>
    </p>

    <p style="font-size:13px; color:#666;">Если вы не создавали эту запись — свяжитесь с поддержкой.</p>
{% endblock %}
