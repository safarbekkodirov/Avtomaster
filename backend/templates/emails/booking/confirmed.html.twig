{% extends 'emails/layout.html.twig' %}

{% block title %}Запись подтверждена — Avtomaster{% endblock %}

{% block content %}
    <h2 style="margin-top:0; color:#28a745;">Запись подтверждена!</h2>
    <p>Мастер <strong>{{ booking.master.firstName|default('') }} {{ booking.master.lastName|default('') }}</strong> подтвердил вашу запись.</p>

    <div class="info-box">
        <div class="info-row">
            <span class="label">Дата и время</span>
            <span class="value">{{ booking.slot.date }}, {{ booking.slot.startTime }}</span>
        </div>
        <div class="info-row">
            <span class="label">Адрес</span>
            <span class="value">{{ booking.master.address|default('Уточните у мастера') }}</span>
        </div>
        <div class="info-row">
            <span class="label">Услуга</span>
            <span class="value">{{ booking.service.name|default('') }}</span>
        </div>
    </div>

    <p>Добавьте визит в календарь, чтобы не забыть.</p>

    <p style="text-align:center;">
        <a href="{{ frontend_url }}/booking/{{ booking.id }}" class="btn">Детали записи</a>
    </p>
{% endblock %}
